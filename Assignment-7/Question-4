package pack;

import java.sql.*;
import java.util.Scanner; 

public class InsertStudentRecord {
    public static void main (String [] args )
    {
        String url ="jdbc:postgresql://192.168.1.17:5432/cse_db24";
		String username = "24bcsf87";
		String password = "24bcsf87";
		
		String query = "INSERT INTO Students (roll_no, name, age, department, cgpa) VALUES (?, ?, ?, ?, ?)";
		
		Scanner sc = new Scanner (System.in);
		
		try
		{
		    System.out.print("Enter Roll No. : ");
		    int rollNo = sc.nextInt();
		    sc.nextLine();
		    
		    System.out.print("Enter name : ");
		    String name = sc.nextLine();
		    
		    System.out.print("Enter age : ");
		    int age = sc.nextInt();
		    sc.nextLine();
		    
		    System.out.print("Enter Department : ");
		    String department = sc.nextLine();
		    
		    System.out.print("Enter CGPA : ");
		    float cgpa = sc.nextFloat();
		    
		    Connection conn = DriverManager.getConnection(url, username, password);
		    
		    PreparedStatement pstmt = conn.prepareStatement(query);
		    
		    pstmt.setInt(1,rollNo);
		    pstmt.setString(2,name);
		    pstmt.setInt(3,age);
		    pstmt.setString(4,department);
		    pstmt.setFloat(5,cgpa);
		    
		    int rows = pstmt.executeUpdate();
		    
		    if(rows > 0)
		    {
		        System.out.print("Student record inserted successfully!");
		    }
		    
		    pstmt.close();
		    conn.close();
		}
		catch (SQLException e)
		{
		    System.out.println("Error inserting record!");
		    e.printStackTrace();
		}
		finally
		{
		    sc.close();
		}
    }
}

