<html>
<head>
<title>Array</title>
<script>
var a = new Array();  

for (i = 0; i < 5; i++) {
    a[i] = prompt("Enter number " + (i+1));  
}

document.write("Entered numbers:<br>");
for (i = 0; i < 5; i++) {
    document.write(a[i] + "<br>");  
}
</script>
</head>
<body bgcolor="red" text="blue">
</body>
</html>
