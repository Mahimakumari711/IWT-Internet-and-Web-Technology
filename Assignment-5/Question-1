<html>  
<head>  
    <script>  
        let marks = 50, grade;  
        if (marks >= 90) {  
            grade = "Grade A";  
        } else if (marks >= 75) {  
            grade = "Grade B";  
        } else if (marks >= 50) {  
            grade = "Grade C";  
        } else {  
            grade = "Fail";  
        }  
        document.write(grade);  
    </script>  
</head>  
</html> 
