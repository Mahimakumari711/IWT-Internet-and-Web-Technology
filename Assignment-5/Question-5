<html>  
<head>  
    <script>  
        let array = [1, 2, 3, 4, 5];  
        let largest = second_largest = array[0];  
        for (let i = 0; i < array.length; i++) {  
            if (array[i] > largest) {  
                second_largest = largest;  
                largest = array[i];  
            } else if (array[i] > second_largest && array[i] != largest) {  
                second_largest = array[i];  
            }  
        }  
        document.write("Second Largest: " + second_largest);  
    </script>  
</head>  
</html> 
