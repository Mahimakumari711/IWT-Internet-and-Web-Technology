<html>  
<head>  
    <script>  
        function isPrime(n) {  
            for (let i = 2; i <= n / 2; i++) {  
                if (n % i == 0) {  
                    return false;  
                }  
            }  
            return true;  
        }  
        let num = 17;  
        if (isPrime(num)) {  
            document.write(num + " is a prime number.");  
        } else {  
            document.write(num + " is not a prime number.");  
        }  
    </script>  
</head>  
</html> 
