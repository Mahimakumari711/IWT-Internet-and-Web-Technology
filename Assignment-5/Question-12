<html>  
<head>  
    <script>  
        function generateFibonacci(n) {  
            let array = [ ];  
            if (n <= 0) { 
                return array;  
            }  
            array[0] = 0;  
            if (n > 1) {  
                array[1] = 1;  
            }  
            for (let i = 2; i < n; i++) {  
                array[i] = array[i - 1] + array[i - 2];  
            }  
            return array;  
        }  
        let num = 7;  
        document.write("Fibonacci till " + num + " numbers are: " + generateFibonacci(num));  
    </script>  
</head>  
</html> 
