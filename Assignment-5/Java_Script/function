<html>
<head>
<title>Addition of two number using function</title>
<script>
function add(a, b) {
    return a + b;
}

var a = parseFloat(prompt("Enter the first number : "));
var b = parseFloat(prompt("Enter the second number : "));

document.write("Addition: " + add(a, b) + "<br>");
document.write("Power: " + Math.pow(a, b) + "<br>");
document.write("Square root of first number: " + Math.sqrt(a) + "<br>");
document.write("Ceiling of first number: " + Math.ceil(a) + "<br>");
document.write("Floor of first number: " + Math.floor(a) + "<br>");
document.write("Round off first number: " + Math.round(a) + "<br>");
document.write("Absolute value of first number: " + Math.abs(a) + "<br>");
document.write("Sin of first number (radians): " + Math.sin(a) + "<br>");
document.write("Cos of first number (radians): " + Math.cos(a) + "<br>");
document.write("Tan of first number (radians): " + Math.tan(a) + "<br>");
document.write("Maximum number: " + Math.max(a, b) + "<br>");
document.write("Minimum number: " + Math.min(a, b) + "<br>");
</script>
</head>
<body bgcolor="yellow" text="brown">
</body>
</html>
