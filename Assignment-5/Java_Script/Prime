<html>
<head>
<title>Prime</title>
</head>
<body bgcolor=orange text=brown>
Enter number: <input id="num" type=number maxlength=3>
<button onclick="n=parseInt(document.getElementById('num').value);
i=1;
c=0;
while(i<=n){
if(n%i==0){
c++;
i++;
}
}
document.getElementById('result').innerHTML=c==2?'<h1>Prime</h1>':'<h1>Not Prime</h1>';">Check
</button>
<div id="result"></div>
</body>
</html>
