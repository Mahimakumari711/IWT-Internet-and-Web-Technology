<html>  
<head>  
    <script>  
        function isArmstrong(n) {  
            let count = Math.ceil(Math.log10(n)), res = 0, temp = n;  
            while (temp) {  
                res += Math.pow(temp % 10, count);  
                temp = Math.floor(temp / 10);  
            }  
            return n == res;  
        }  
        let num = 153;  
        if (isArmstrong(num)) {  
            document.write(num + " is an Armstrong number.");  
        } else {  
            document.write(num + " is not an Armstrong number.");  
        }  
    </script>  
</head>  
</html>
