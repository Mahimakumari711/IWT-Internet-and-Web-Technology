<html>  
<head>  
    <script>  
        let array = [1, 2, 3, 4, 5];  
        let sum = 0, smallest = largest = array[0];  
        for (let i = 0; i < array.length; i++) {  
            sum += array[i];  
            if (largest < array[i]) {  
                largest = array[i];  
            }  
            if (smallest > array[i]) {  
                smallest = array[i];  
            }  
        }  
        document.write("Sum: " + sum+"<br>");  
        document.write("Avg: " + (sum / array.length)+"<br>");  
        document.write("Largest: " + largest+"<br>");  
        document.write("Smallest: " + smallest+"<br>");  
    </script>  
</head>  
</html> 
